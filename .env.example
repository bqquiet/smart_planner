# ── Required ───────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Database ───────────────────────────────────────────────────────────────────
# Local SQLite (default, no setup needed):
# DATABASE_URL=sqlite+aiosqlite:///smart_planner.db

# PostgreSQL local:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smart_planner

# Railway автоматично встановлює DATABASE_URL — не треба заповнювати вручну

# ── Webhook (тільки для production на Railway/Render) ──────────────────────────
# Railway автоматично надає домен — встав його сюди:
# WEBHOOK_HOST=https://your-app-name.up.railway.app
# WEBHOOK_PATH=/webhook

# ── Scheduler ──────────────────────────────────────────────────────────────────
REMINDER_MINUTES_BEFORE=60
OVERDUE_CHECK_INTERVAL=300

# ── Debug ──────────────────────────────────────────────────────────────────────
DB_ECHO=false

# ── Admin ──────────────────────────────────────────────────────────────────────
# ADMIN_IDS=123456789,987654321

# ── AI (OpenAI) ────────────────────────────────────────────────────────────────
# Отримати ключ: https://platform.openai.com/api-keys
# Без цього ключа AI-функції просто вимкнені — бот працює в звичайному режимі
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
